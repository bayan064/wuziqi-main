/* pages/room/room.wxss */
page {
  background-color: #fdf6e3;
}

/* 初始隐藏 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 30rpx 20rpx;
  box-sizing: border-box;

  opacity: 0;
  transform: translateX(100%);
}

/* 激活后整体滑入 */
.container.active {
  opacity: 1;
  transform: translateX(0);
  transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

/* 头部 */
.header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 0 20rpx;
}

.back-btn {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b4513;
  background-color: #fff;
  padding: 15rpx 25rpx;
  border-radius: 40rpx;
  border: 4rpx solid #8b4513;
  box-shadow: 0 6rpx 0 #d2a679;
  transition: all 0.1s;
}

.back-btn:active {
  transform: translateY(6rpx);
  box-shadow: 0 0 0 #d2a679;
}

.title {
  font-size: 44rpx;
  font-weight: 900;
  color: #ff7f50;
  -webkit-text-stroke: 2rpx #8b4513;
  text-shadow: 4rpx 4rpx 0 #8b4513;
  letter-spacing: 2rpx;
}

.placeholder {
  width: 100rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 - 卡通风格 */
.card {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 40rpx 30rpx;
  border: 6rpx solid #8b4513;
  box-shadow: 0 12rpx 0 #d2a679;
  transition: all 0.1s;
  text-align: center;
}

.card:active {
  transform: translateY(6rpx);
  box-shadow: 0 6rpx 0 #d2a679;
}

/* 加入卡片内部按钮不需要整体缩放 */
.join-card:active {
  transform: none;
}

.card-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 38rpx;
  font-weight: 900;
  color: #ffaa00;
  -webkit-text-stroke: 1.5rpx #8b4513;
  margin-bottom: 15rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
  margin-bottom: 30rpx;
}

/* 输入框样式 */
.room-input {
  width: 100%;
  height: 80rpx;
  background-color: #fdf6e3;
  border: 4rpx solid #8b4513;
  border-radius: 50rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  text-align: center;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  box-sizing: border-box;
}

/* 加入按钮 */
.join-btn {
  width: 100% !important;
  height: 80rpx;
  line-height: 80rpx;
  vertical-align: middle;
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%) !important;
  color: white !important;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  border: 4rpx solid #8b4513;
  box-shadow: 0 8rpx 0 #2c7da0;
  transition: all 0.1s;
  margin: 0 auto; 
  display: block; 
}

.join-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #2c7da0;
}

/* 徽章 */
.badge {
  display: inline-block;
  background-color: #ffaa00;
  color: white;
  font-size: 24rpx;
  font-weight: bold;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  margin-top: 20rpx;
  border: 2rpx solid #8b4513;
}

/* 创建房间按钮特殊颜色 */
.create-card .card-title {
  color: #f5576c;
}

/* 随机匹配卡片半透明 */
.random-card {
  opacity: 0.8;
}